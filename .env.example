# Application Environment
# Options: development | production
# development: enables SQL echo, verbose logging
# production: disables SQL echo, quieter output
APP_ENV=development

# AI Configuration
# Options: openai, google_gemini, anthropic, deepseek, openrouter
AI_PROVIDER=google_gemini
AI_MODEL=gemini/gemini-1.5-flash

# API Keys
GEMINI_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# Database
DATABASE_URL=sqlite:///./loom.db
