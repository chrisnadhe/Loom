!Configuration Built on {{ now }}
! Arista EOS - Generated by Loom
!
configure
!
hostname {{ hostname }}
!
{% if domain_name|length > 0 %}
dns domain {{ domain_name }}
!
{% endif %}
{% if timezone|length > 0 %}
clock timezone {{ timezone }}
!
{% endif %}
! === Management & AAA ===
!
{% if username|length > 0 %}
username {{ username }} privilege 15 {% if algorithm_type == 'sha256' %}secret sha512{% else %}secret{% endif %} {{ password }}
!
{% endif %}
{% if enable_password|length > 0 %}
enable secret {{ enable_password }}
!
{% endif %}
aaa authentication login default local
aaa authorization exec default local
!
! === SSH ===
!
management ssh
   {% if ssh_key_size|length > 0 %}
   authentication keys rsa {{ ssh_key_size }}
   {% endif %}
   idle-timeout {{ timeout if timeout|length > 0 else '5' }}
   no shutdown
!
{% if ssh_version == '2' %}
ip ssh version 2
!
{% endif %}
! === Line VTY ===
!
management api http-commands
{% if http_server == 'no' %}
   no protocol http
   no protocol https
{% else %}
   protocol http
   protocol https
{% endif %}
   no shutdown
!
{% if lldp == 'yes' %}
lldp run
!
{% endif %}
! === Logging ===
!
{% if logging_console|length > 0 %}
logging console {{ logging_console }}
{% endif %}
{% if logging_buffer_size|length > 0 %}
logging buffered {{ logging_buffer_size }}
{% endif %}
!
! === STP ===
!
{% if stp_mode == 'rapid-pvst' or stp_mode == 'pvst' %}
spanning-tree mode rapid-pvst
{% elif stp_mode == 'mst' %}
spanning-tree mode mstp
{% endif %}
!
! === Banner ===
!
banner login
{% if banner_motd|length > 0 %}
{{ banner_motd }}
{% else %}
############################################################
#                                                          #
#  UNAUTHORIZED ACCESS TO THIS DEVICE IS PROHIBITED       #
#                                                          #
#  You MUST have explicit permission to access or          #
#  configure this device. Unauthorized use is illegal.     #
#                                                          #
############################################################
{% endif %}
EOF
!
! === VLANs ===
!
{% for vlan in vlans %}
{% if vlan.id|int <= 4094 %}
vlan {{ vlan.id }}
   name {{ vlan.name|replace(" ", "_")|truncate(32, True, "") }}
!
{% if vlan.ip_addr|length > 0 %}
interface Vlan{{ vlan.id }}
{% if vlan.description|length > 0 %}
   description *** {{ vlan.description }} ***
{% endif %}
   ip address {{ vlan.ip_addr }}/{{ vlan.mask | to_cidr }}
   no shutdown
!
{% endif %}
{% else %}
!! ERROR: VLAN ID {{ vlan.id }} is out of range (1-4094)
{% endif %}
{% endfor %}
! === Port-Channel (Etherchannel) ===
!
{% for portchannel in etherchannels %}
interface Port-Channel{{ portchannel.id }}
{% if portchannel.description|length > 0 %}
   description *** {{ portchannel.description }} ***
{% endif %}
{% if portchannel.type|upper == 'L2' %}
   switchport
   switchport mode {{ portchannel.mode }}
{% if portchannel.mode == 'access' and portchannel.access_vlan|length > 0 %}
   switchport access vlan {{ portchannel.access_vlan }}
{% endif %}
{% if portchannel.mode == 'trunk' and portchannel.native_vlan|length > 0 %}
   switchport trunk native vlan {{ portchannel.native_vlan }}
{% endif %}
{% if portchannel.mode == 'trunk' and portchannel.allowed_vlans|length > 0 and portchannel.allowed_vlans != 'all' %}
   switchport trunk allowed vlan {{ portchannel.allowed_vlans }}
{% endif %}
{% endif %}
{% if portchannel.type|upper == 'L3' %}
   no switchport
   ip address {{ portchannel.ip_addr }}/{{ portchannel.mask | to_cidr }}
{% endif %}
   no shutdown
!
{% endfor %}
! === Interfaces ===
!
{% for port in interfaces %}
interface {{ port.name }}
{% if port.description|length > 0 %}
   description *** {{ port.description }} ***
{% endif %}
{% if port.mode == 'access' %}
   switchport
   switchport mode access
{% if port.access_vlan|length > 0 %}
   switchport access vlan {{ port.access_vlan }}
{% endif %}
{% if port.voice_vlan|length > 0 %}
   switchport voice vlan {{ port.voice_vlan }}
{% endif %}
{% endif %}
{% if port.mode == 'trunk' %}
   switchport
   switchport mode trunk
{% if port.native_vlan|length > 0 %}
   switchport trunk native vlan {{ port.native_vlan }}
{% endif %}
{% if port.allowed_vlans|length > 0 and port.allowed_vlans != 'all' %}
   switchport trunk allowed vlan {{ port.allowed_vlans }}
{% endif %}
{% endif %}
{% if port.portfast == 'yes' %}
   spanning-tree portfast
{% endif %}
{% if port.bpduguard == 'yes' %}
   spanning-tree bpduguard enable
{% endif %}
{% if port.portsecurity == 'yes' %}
   switchport port-security
   switchport port-security mac-address sticky
{% endif %}
   no shutdown
!
{% endfor %}
end
!
