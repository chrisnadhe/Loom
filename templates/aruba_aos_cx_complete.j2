! Configuration Built on {{ now }}
! Aruba AOS-CX - Generated by Loom
!
configure terminal
!
hostname {{ hostname }}
!
{% if domain_name|length > 0 %}
ip domain-name {{ domain_name }}
!
{% endif %}
{% if timezone|length > 0 %}
clock timezone {{ timezone }}
!
{% endif %}
! === User & AAA ===
!
{% if username|length > 0 %}
user {{ username }} group administrators password {% if algorithm_type == 'sha256' %}sha256{% else %}ciphertext{% endif %} {{ password }}
!
{% endif %}
aaa authentication login default local
aaa authentication enable default local
!
! === SSH & Management ===
!
{% if ssh_key_size|length > 0 %}
ssh key rsa {{ ssh_key_size }}
{% endif %}
{% if ssh_version == '2' %}
ssh strictversions
{% endif %}
!
https-server rest access-mode read-write
!
{% if http_server == 'no' %}
no https-server vrf default
{% else %}
https-server vrf default
{% endif %}
!
{% if lldp == 'yes' %}
lldp enable
!
{% endif %}
! === Logging ===
!
{% if logging_console|length > 0 %}
logging severity {{ logging_console }}
{% endif %}
{% if logging_buffer_size|length > 0 %}
logging buffered {{ logging_buffer_size }}
{% endif %}
!
! === STP ===
!
{% if stp_mode == 'rapid-pvst' %}
spanning-tree mode rpvst
{% elif stp_mode == 'pvst' %}
spanning-tree mode pvst
{% elif stp_mode == 'mst' %}
spanning-tree mode mstp
{% endif %}
!
! === Banner ===
!
banner motd
#################** D I S C L A I M E R **##################
#                                                          #
#  UNAUTHORIZED ACCESS TO THIS DEVICE IS PROHIBITED       #
#                                                          #
############################################################

!
! === VLANs ===
!
{% for vlan in vlans %}
{% if vlan.id|int <= 4094 %}
vlan {{ vlan.id }}
    name {{ vlan.name|replace(" ", "_")|truncate(32, True, "") }}
!
{% if vlan.ip_addr|length > 0 %}
interface vlan {{ vlan.id }}
{% if vlan.desc|length > 0 %}
    description *** {{ vlan.desc }} ***
{% endif %}
    ip address {{ vlan.ip_addr }}/{{ vlan.mask }}
    no shutdown
!
{% endif %}
{% else %}
!! ERROR: VLAN ID {{ vlan.id }} is out of range (1-4094)
{% endif %}
{% endfor %}
! === LAG (Etherchannel) ===
!
{% for portchannel in etherchannels %}
interface lag {{ portchannel.id }}
{% if portchannel.desc|length > 0 %}
    description *** {{ portchannel.desc }} ***
{% endif %}
{% if portchannel.type|upper == 'L2' %}
    no routing
    vlan mode {{ portchannel.mode }}
{% if portchannel.mode == 'access' and portchannel.access_vlan|length > 0 %}
    vlan access {{ portchannel.access_vlan }}
{% endif %}
{% if portchannel.mode == 'trunk' and portchannel.native_vlan|length > 0 %}
    vlan trunk native {{ portchannel.native_vlan }}
{% endif %}
{% if portchannel.mode == 'trunk' and portchannel.allowed_vlans|length > 0 and portchannel.allowed_vlans != 'all' %}
    vlan trunk allowed {{ portchannel.allowed_vlans }}
{% endif %}
{% endif %}
{% if portchannel.type|upper == 'L3' %}
    routing
    ip address {{ portchannel.ip_addr }}/{{ portchannel.mask }}
{% endif %}
    lacp mode active
    no shutdown
!
{% endfor %}
! === Interfaces ===
!
{% for port in interfaces %}
interface {{ port.name }}
{% if port.description|length > 0 %}
    description *** {{ port.description }} ***
{% endif %}
{% if port.mode == 'access' %}
    no routing
    vlan mode access
{% if port.access_vlan|length > 0 %}
    vlan access {{ port.access_vlan }}
{% endif %}
{% if port.voice_vlan|length > 0 %}
    vlan voice {{ port.voice_vlan }}
{% endif %}
{% endif %}
{% if port.mode == 'trunk' %}
    no routing
    vlan mode trunk
{% if port.native_vlan|length > 0 %}
    vlan trunk native {{ port.native_vlan }}
{% endif %}
{% if port.allowed_vlans|length > 0 and port.allowed_vlans != 'all' %}
    vlan trunk allowed {{ port.allowed_vlans }}
{% endif %}
{% endif %}
{% if port.portfast == 'yes' %}
    spanning-tree port-type admin-edge
{% endif %}
{% if port.bpduguard == 'yes' %}
    spanning-tree bpdu-guard
{% endif %}
{% if port.portsecurity == 'yes' %}
    port-security
    port-security mac-address sticky
    port-security violation restrict
{% endif %}
    no shutdown
!
{% endfor %}
! === VTY Lines ===
!
{% if vty_lines|length > 0 %}
ssh max-sessions {{ vty_lines }}
{% endif %}
{% if timeout|length > 0 %}
ssh idle-timeout {{ timeout }}
{% endif %}
!
end
!
